# Django
SECRET_KEY=change-me
DEBUG=1
# Laisser vide en dev : le projet accepte tout hôte (localhost, IP locale, nom PC).
# En prod : liste explicite, ex. ALLOWED_HOSTS=www.mondomaine.fr,mondomaine.fr
ALLOWED_HOSTS=

# Base de données
# En dev, vous pouvez laisser vide pour utiliser SQLite.
DATABASE_URL=

# Clé chiffrement Fernet (à remplacer par une clé Fernet valide)
ENCRYPTION_KEY=change-me-to-a-fernet-key

# Email (dev)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=no-reply@comptanextgen.fr
